# axon.ai 本地环境变量模板 / local environment template
# 复制为 .env 后填写真实 key；.env 已被 .gitignore 排除，不会提交。

# ── LLM ──────────────────────────────────────────────────
# 显式指定 provider: openai | deepseek
LLM_PROVIDER=deepseek

# DeepSeek V4 Pro (OpenAI 兼容 API)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro

# 或 OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ── Embedding ────────────────────────────────────────────
# 目前仅支持 OpenAI embedding；DeepSeek 暂无 embedding API。
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Memory ───────────────────────────────────────────────
AXON_MEMORY_REDB_PATH=.axon/memory.redb
AXON_MEMORY_QDRANT_URL=http://localhost:6334
AXON_MEMORY_QDRANT_COLLECTION=axon_memories
